# ============================================
# Gradle Build System
# ============================================

# Gradle build output and cache directories
.gradle/
build/
.gradletasknamecache

# Ignore Gradle GUI config
gradle-app.setting

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar

# ============================================
# IntelliJ IDEA
# ============================================
.idea/
*.iml
*.ipr
*.iws
/out/

# ============================================
# Eclipse
# ============================================
.classpath
.project
.checkstyle
.factorypath
.settings/
bin/

# ============================================
# VS Code
# ============================================
.vscode/

# ============================================
# Operating System Files
# ============================================
.DS_Store
Thumbs.db

# ============================================
# Compiled Output & Archives
# ============================================
*.class
*.jar
*.war
*.ear

# ============================================
# Logs & Temporary Files
# ============================================
*.log
*.tmp
*.bak
*.swp
*~

# ============================================
# Java Heap Dump
# ============================================
*.hprof